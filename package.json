{
  "name": "@jelmore1674/build-changelog",
  "version": "1.3.3",
  "description": "",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ncc build src/index.ts -m && cp -R templates dist/",
    "build:actions": "pnpm build:enforcer && pnpm build:generate && pnpm build:notes",
    "build:enforcer": "ncc build src/enforcer.ts -m -o enforcer && cp -R templates enforcer/",
    "build:generate": "ncc build src/generate.ts -m -o generate && cp -R templates generate/",
    "build:notes": "ncc build src/notes.ts -m -o notes && cp -R templates notes/",
    "lint": "biome lint --error-on-warnings",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "jelmore1674",
  "license": "ISC",
  "packageManager": "pnpm@10.8.0+sha512.0e82714d1b5b43c74610193cb20734897c1d00de89d0e18420aebc5977fa13d780a9cb05734624e81ebd81cc876cd464794850641c48b9544326b5622ca29971",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@iarna/toml": "2.2.5",
    "@jelmore1674/changelog": "^0.2.8",
    "fs-extra": "11.3.0",
    "latest-semver": "^4.0.0",
    "mustache": "4.2.0",
    "semver": "^7.7.1",
    "yaml": "2.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/fs-extra": "11.0.4",
    "@types/iarna__toml": "2.0.5",
    "@types/mustache": "4.2.5",
    "@types/node": "22.13.9",
    "@types/semver": "7.7.0",
    "@vercel/ncc": "0.38.3",
    "@vitest/coverage-v8": "3.1.1",
    "commander": "13.1.0",
    "dprint": "0.49.1",
    "typescript": "5.8.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.1.1"
  },
  "bin": {
    "bcl": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "engineStrict": true
}
