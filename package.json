    "@types/semver": "7.7.1",
    "@vercel/ncc": "0.38.4",
    "@vitest/coverage-v8": "4.1.5",
    "commander": "14.0.3",
    "dprint": "0.54.0",
    "memfs": "^4.57.2",
    "nock": "^14.0.13",
